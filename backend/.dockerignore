# ============================================================================
# Backend .dockerignore Configuration
# ============================================================================
# This file optimizes Docker build context by excluding unnecessary files
# IMPORTANT: Files needed for Docker build must NOT be excluded here
# ============================================================================

# Dependencies (node_modules will be installed fresh in Docker)
node_modules
npm-debug.log
yarn-error.log
yarn.lock
pnpm-lock.yaml

# Build outputs (dist is built inside Docker)
*.tsbuildinfo

# Testing files (not needed in production)
coverage
.nyc_output
test
tests
*.test.ts
*.test.js
*.spec.ts
*.spec.js
__tests__
jest.config.js

# Environment variables (set via docker-compose.yml or runtime)
.env
.env.*
!.env.example

# IDE and OS files
.vscode
.idea
*.swp
*.swo
.DS_Store
Thumbs.db
*.log

# Git files
.git
.gitignore
.gitattributes

# CI/CD files
.github
.gitlab-ci.yml
.travis.yml
.circleci

# Documentation (not needed in runtime container)
README.md
CHANGELOG.md
docs
*.md
!CRITICAL*.md

# Temporary files
.cache
.temp
tmp
temp
*.tmp

# ============================================================================
# CRITICAL: DO NOT EXCLUDE THESE FILES (they are required for Docker build)
# ============================================================================
# package.json - Required for npm install
# package-lock.json - Required for reproducible builds
# docker-entrypoint.sh - Required for container startup (MUST BE INCLUDED)
# prisma/schema.prisma - Required for Prisma operations
# prisma/migrations/ - Required for database migrations
# src/ - Required for TypeScript compilation
# tsconfig.json - Required for TypeScript build
# ============================================================================
