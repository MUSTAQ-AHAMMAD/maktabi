# Default credentials match the docker-compose.yml PostgreSQL setup for local development.
# IMPORTANT: Change these values before deploying to production.
#
# DATABASE_URL format: postgresql://<user>:<password>@<host>:<port>/<database>
#
# Windows users: this project requires PostgreSQL (not MySQL/MariaDB).
# XAMPP does NOT include PostgreSQL — install it from https://www.postgresql.org/download/windows/
# After installing PostgreSQL, create the database user and database as described in the README,
# then copy this file to .env (Windows Command Prompt: copy .env.example .env)
# and update the credentials below if you chose different values during setup.
DATABASE_URL="postgresql://maktabi:maktabi123@localhost:5432/maktabi_db"
JWT_SECRET="maktabi-super-secret-jwt-key-2024"
PORT=3001
FRONTEND_URL="http://localhost:3000"
