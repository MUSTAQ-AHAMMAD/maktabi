generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  ADMIN
  LEGAL_MANAGER
  INTERNAL_LAWYER
  EXTERNAL_LAWYER
  HR
  FINANCE
  DEPARTMENT_MANAGER
  EMPLOYEE
  CEO
}

enum CaseStatus {
  DRAFT
  PENDING
  IN_REVIEW
  ASSIGNED
  IN_PROGRESS
  HEARING
  DECIDED
  CLOSED
  ARCHIVED
}

enum RiskLevel {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum InvestigationStatus {
  SUBMITTED
  CLASSIFIED
  IN_PROGRESS
  COMMITTEE_REVIEW
  APPEAL
  CLOSED
  ARCHIVED
}

enum ConsultationStatus {
  SUBMITTED
  IN_REVIEW
  OPINION_PROVIDED
  CLOSED
}

enum ContractStatus {
  DRAFT
  PENDING_MANAGER
  PENDING_LEGAL
  PENDING_LAWYER
  PENDING_CEO
  APPROVED
  ACTIVE
  EXPIRED
  TERMINATED
}

enum FinancialExecutionType {
  AGAINST_COMPANY
  IN_FAVOR_OF_COMPANY
}

enum FinancialExecutionStatus {
  PENDING
  IN_PROGRESS
  PARTIAL
  COMPLETED
  CANCELLED
}

model User {
  id            String   @id @default(cuid())
  email         String   @unique
  password      String
  firstName     String
  lastName      String
  role          Role     @default(EMPLOYEE)
  department    String?
  isActive      Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  deletedAt     DateTime?

  assignedCases         LitigationCase[]       @relation("AssignedLawyer")
  createdCases          LitigationCase[]       @relation("CaseCreator")
  investigations        Investigation[]        @relation("InvestigationCreator")
  consultations         Consultation[]         @relation("ConsultationCreator")
  contracts             Contract[]             @relation("ContractCreator")
  approvals             ApprovalLog[]
  auditLogs             AuditLog[]             @relation("AuditUser")
  notifications         Notification[]

  @@index([email])
  @@index([role])
}

model LitigationCase {
  id                String      @id @default(cuid())
  caseNumber        String      @unique
  caseType          String
  courtName         String
  parties           String
  description       String      @db.Text
  riskLevel         RiskLevel   @default(MEDIUM)
  financialExposure Decimal?    @db.Decimal(15, 2)
  currency          String      @default("SAR")
  status            CaseStatus  @default(DRAFT)
  assignedLawyerId  String?
  createdById       String
  slaDeadline       DateTime?
  closedAt          DateTime?
  createdAt         DateTime    @default(now())
  updatedAt         DateTime    @updatedAt
  deletedAt         DateTime?

  assignedLawyer    User?       @relation("AssignedLawyer", fields: [assignedLawyerId], references: [id])
  createdBy         User        @relation("CaseCreator", fields: [createdById], references: [id])
  hearings          Hearing[]
  documents         Document[]

  @@index([status])
  @@index([riskLevel])
  @@index([assignedLawyerId])
}

model Hearing {
  id          String   @id @default(cuid())
  caseId      String
  hearingDate DateTime
  court       String
  notes       String?  @db.Text
  outcome     String?  @db.Text
  nextDate    DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  case        LitigationCase @relation(fields: [caseId], references: [id])

  @@index([caseId])
  @@index([hearingDate])
}

model Investigation {
  id               String              @id @default(cuid())
  title            String
  description      String              @db.Text
  severity         String              @default("MEDIUM")
  isConfidential   Boolean             @default(false)
  status           InvestigationStatus @default(SUBMITTED)
  createdById      String
  committeeMembers String[]
  disciplinaryLog  String?             @db.Text
  appealNotes      String?             @db.Text
  slaDeadline      DateTime?
  closedAt         DateTime?
  createdAt        DateTime            @default(now())
  updatedAt        DateTime            @updatedAt
  deletedAt        DateTime?

  createdBy        User                @relation("InvestigationCreator", fields: [createdById], references: [id])
  documents        Document[]

  @@index([status])
}

model Consultation {
  id           String             @id @default(cuid())
  title        String
  description  String             @db.Text
  status       ConsultationStatus @default(SUBMITTED)
  createdById  String
  legalOpinion String?            @db.Text
  tags         String[]
  templateId   String?
  slaDeadline  DateTime?
  closedAt     DateTime?
  feedback     String?
  createdAt    DateTime           @default(now())
  updatedAt    DateTime           @updatedAt
  deletedAt    DateTime?

  createdBy    User               @relation("ConsultationCreator", fields: [createdById], references: [id])
  documents    Document[]

  @@index([status])
}

model Contract {
  id              String         @id @default(cuid())
  title           String
  contractNumber  String         @unique
  description     String         @db.Text
  value           Decimal?       @db.Decimal(15, 2)
  currency        String         @default("SAR")
  status          ContractStatus @default(DRAFT)
  createdById     String
  counterparty    String
  startDate       DateTime?
  endDate         DateTime?
  renewalAlertDays Int           @default(30)
  riskScore       Int?
  clauseNotes     String?        @db.Text
  signatureReady  Boolean        @default(false)
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt
  deletedAt       DateTime?

  createdBy       User           @relation("ContractCreator", fields: [createdById], references: [id])
  documents       Document[]

  @@index([status])
  @@index([endDate])
}

model FinancialExecution {
  id             String                   @id @default(cuid())
  title          String
  type           FinancialExecutionType
  status         FinancialExecutionStatus @default(PENDING)
  totalAmount    Decimal                  @db.Decimal(15, 2)
  paidAmount     Decimal                  @default(0) @db.Decimal(15, 2)
  currency       String                   @default("SAR")
  dueDate        DateTime?
  caseId         String?
  notes          String?                  @db.Text
  createdAt      DateTime                 @default(now())
  updatedAt      DateTime                 @updatedAt
  deletedAt      DateTime?

  payments       Payment[]
  documents      Document[]

  @@index([status])
  @@index([type])
}

model Payment {
  id                   String             @id @default(cuid())
  financialExecutionId String
  amount               Decimal            @db.Decimal(15, 2)
  currency             String             @default("SAR")
  paymentDate          DateTime
  reference            String?
  notes                String?
  createdAt            DateTime           @default(now())

  financialExecution   FinancialExecution @relation(fields: [financialExecutionId], references: [id])

  @@index([financialExecutionId])
}

model Document {
  id              String   @id @default(cuid())
  filename        String
  originalName    String
  mimeType        String
  size            Int
  path            String
  version         Int      @default(1)
  uploadedById    String
  caseId          String?
  investigationId String?
  consultationId  String?
  contractId      String?
  financialId     String?
  createdAt       DateTime @default(now())

  case               LitigationCase?    @relation(fields: [caseId], references: [id])
  investigation      Investigation?     @relation(fields: [investigationId], references: [id])
  consultation       Consultation?      @relation(fields: [consultationId], references: [id])
  contract           Contract?          @relation(fields: [contractId], references: [id])
  financialExecution FinancialExecution? @relation(fields: [financialId], references: [id])

  @@index([caseId])
  @@index([contractId])
}

model WorkflowState {
  id            String   @id @default(cuid())
  entityType    String
  entityId      String
  fromStatus    String?
  toStatus      String
  action        String
  performedById String
  notes         String?
  createdAt     DateTime @default(now())

  @@index([entityType, entityId])
}

model ApprovalLog {
  id         String   @id @default(cuid())
  entityType String
  entityId   String
  action     String
  approverId String
  notes      String?
  createdAt  DateTime @default(now())

  approver   User     @relation(fields: [approverId], references: [id])

  @@index([entityType, entityId])
}

model AuditLog {
  id         String   @id @default(cuid())
  userId     String
  action     String
  entityType String
  entityId   String?
  oldValues  Json?
  newValues  Json?
  ipAddress  String?
  userAgent  String?
  createdAt  DateTime @default(now())

  user       User     @relation("AuditUser", fields: [userId], references: [id])

  @@index([userId])
  @@index([entityType, entityId])
  @@index([createdAt])
}

model Notification {
  id         String   @id @default(cuid())
  userId     String
  title      String
  message    String
  type       String   @default("INFO")
  isRead     Boolean  @default(false)
  entityType String?
  entityId   String?
  createdAt  DateTime @default(now())

  user       User     @relation(fields: [userId], references: [id])

  @@index([userId, isRead])
}
